{
  "name": "hermes-polymarket-bot",
  "version": "1.0.0",
  "description": "Hermes-powered Polymarket copy trading research system - paper trading only",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma migrate deploy && prisma db seed && next build",
    "build:vercel": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "scan:leaderboard": "tsx src/scripts/scan-leaderboard.ts",
    "scan:wallets": "tsx src/scripts/scan-wallets.ts",
    "monitor:trades": "tsx src/scripts/monitor-trades.ts",
    "score:trades": "tsx src/scripts/score-trades.ts",
    "paper:update-pnl": "tsx src/scripts/update-paper-pnl.ts",
    "review:outcomes": "tsx src/scripts/review-outcomes.ts",
    "update:rules": "tsx src/scripts/update-rules.ts",
    "report:daily": "tsx src/scripts/generate-daily-report.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.110.5",
    "axios": "^1.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "dotenv": "^17.4.2",
    "next": "^14.2.0",
    "pg": "^8.22.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.12.0",
    "tailwind-merge": "^2.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.5.2",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.5.17",
    "prisma": "^5.14.0",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vitest": "^1.5.0"
  }
}
