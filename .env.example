# ============================================
# HERMES POLYMARKET COPY TRADING BOT - ENV VARS
# ============================================
# Copy this to .env and fill in your values
# For Vercel: Add each variable in Project Settings → Environment Variables

# -----------------------------------------------------------------------------
# DATABASE (REQUIRED for Vercel)
# -----------------------------------------------------------------------------
# Use Neon (neon.tech), Supabase (supabase.com), or Railway (railway.app) for free PostgreSQL
# Format: postgresql://user:password@host:5432/database?schema=public
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?schema=public"

# -----------------------------------------------------------------------------
# POLYMARKET APIs (Public - no auth needed)
# -----------------------------------------------------------------------------
POLYMARKET_GAMMA_API="https://gamma-api.polymarket.com"
POLYMARKET_CLOB_API="https://clob.polymarket.com"
POLYMARKET_DATA_API="https://data-api.polymarket.com"
BULLPEN_API="https://api.bullpen.fi"

# -----------------------------------------------------------------------------
# TELEGRAM BOT (REQUIRED for daily reports)
# -----------------------------------------------------------------------------
# Get from @BotFather on Telegram
# Format: 123456789:ABCDefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_BOT_TOKEN="8740140016:AAGzGvUIOqSgnC6PjpYApnva1wXCEkjpyy8"

# Get from @userinfobot or your group
# Format: -1001234567890 (negative for groups/channels) or 123456789 (positive for DM)
TELEGRAM_CHAT_ID="1463103481"

# -----------------------------------------------------------------------------
# VERCEL / NEXT.JS
# -----------------------------------------------------------------------------
# Your Vercel deployment URL (update after first deploy)
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# -----------------------------------------------------------------------------
# SCANNING CONFIGURATION (Optional - defaults shown)
# -----------------------------------------------------------------------------
# Lookback days for leaderboard/wallet scans
SCAN_LOOKBACK_DAYS="30"

# Maximum wallets to scan from leaderboard
MAX_WALLETS_TO_SCAN="500"

# -----------------------------------------------------------------------------
# PAPER TRADING CONFIG (Optional - defaults shown)
# -----------------------------------------------------------------------------
# Minimum position size in USD
PAPER_MIN_POSITION="5"

# Maximum position size in USD
PAPER_MAX_POSITION="20"

# Maximum concurrent paper trades
MAX_CONCURRENT_PAPER_TRADES="50"

# -----------------------------------------------------------------------------
# RISK MANAGEMENT (Optional - defaults shown)
# -----------------------------------------------------------------------------
# Maximum portfolio drawdown (20%)
MAX_DRAWDOWN_PERCENT="0.20"

# Stop loss per trade (50%)
STOP_LOSS_PERCENT="0.50"

# Take profit per trade (100%)
TAKE_PROFIT_PERCENT="1.0"

# -----------------------------------------------------------------------------
# NODE / RUNTIME
# -----------------------------------------------------------------------------
NODE_ENV="production"